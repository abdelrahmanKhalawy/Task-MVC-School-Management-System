@model SchoolManagementSystem.Models.Student

<h1>Edit Student</h1>

<form method="post">
    <input type="hidden" name="id" value="@Model.id" />

    <label>Name</label>
    <input type="text" name="name" value="@Model.name" />
    <br>

    <label>Age</label>
    <input type="number" name="age" value="@Model.age" />
    <br>

    <label>Grade</label>
    <input type="text" name="grade" value="@Model.grade" />
    <br>

    <button type="submit">Save</button>
</form>